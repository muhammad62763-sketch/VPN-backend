# ═══════════════════════════════════════════════════════════════════════════════
# VPN BACKEND ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# IMPORTANT: Replace ALL placeholder values with your actual secrets
# NEVER commit real secrets to version control!
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# Get from neon.tech → Your Project → Connection String
NEON_DATABASE_URL=postgresql://username:password@host.region.aws.neon.tech/dbname?sslmode=require

# ── JWT Configuration ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=REPLACE_WITH_RANDOM_64_BYTE_HEX_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Admin Configuration ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
ADMIN_REGISTRATION_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_64_BYTE_HEX_STRING
ADMIN_IP_WHITELIST=[]

# ── Application ───────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
ENVIRONMENT=production

# ── Security ──────────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=900
SESSION_TIMEOUT=3600
REQUIRE_2FA_FOR_ADMIN=true

# ── VPN Configuration ─────────────────────────────────────────────────────────
# Generate with: wg genkey | wg pubkey
WG_SERVER_PUBLIC_KEY=REPLACE_WITH_YOUR_WIREGUARD_PUBLIC_KEY
WG_SERVER_ENDPOINT=your-vps-ip:51820
WG_DNS=1.1.1.1
MAX_DEVICES_PER_USER=5
DEFAULT_BANDWIDTH_LIMIT=107374182400

# ── Signing Keys ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ED25519_PRIVATE_KEY_HEX=REPLACE_WITH_RANDOM_32_BYTE_HEX_STRING

# ── Monitoring ────────────────────────────────────────────────────────────────
ENABLE_METRICS=true
ENABLE_AUDIT_LOGGING=true

# ═══════════════════════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════════
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Generate secrets:
#    openssl rand -hex 64  # For JWT_SECRET_KEY
#    openssl rand -hex 64  # For ADMIN_REGISTRATION_SECRET
#    openssl rand -hex 32  # For ED25519_PRIVATE_KEY_HEX
#
# 3. Set up WireGuard:
#    wg genkey | tee privatekey | wg pubkey > publickey
#
# 4. Configure database:
#    - Create Neon project at neon.tech
#    - Copy connection string to NEON_DATABASE_URL
#
# 5. Update ALLOWED_ORIGINS with your frontend URL
#
# 6. Set ENVIRONMENT=development for local testing
#
# ═══════════════════════════════════════════════════════════════════════════════
